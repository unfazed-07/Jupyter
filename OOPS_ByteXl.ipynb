    "# Reverse a string using recursion\n",
    "def reverse(str):\n",
    "\n",
    "    if len(str)==0:\n",
    "        return \"\"\n",
    "    return str[-1] + reverse(str[:-1])\n",
    "\n",
    "str = \"Freak\"\n",
    "print(reverse(str))"
