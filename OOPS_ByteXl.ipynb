    "def introduce(name, age):\n",
    "  print(\"Name:\", name)\n",
    "  print(\"Age:\", age)\n",
    "  \n",
    "introduce(age = 21, name = \"Riya\")\n",
    "\n",
    "# Default Argument -> usually comes on the most right position\n",
    "def greet(name = \"Student\"):\n",
    "  print(\"Hello\", name )\n",
    "  \n",
    "greet()\n",
    "greet(\"Aditya\")\n",
    "print()\n"
