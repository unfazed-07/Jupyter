    "\n",
    "class Student:\n",
    "    count = 0\n",
    "\n",
    "    def __init__(self, marks):\n",
    "        self.__marks = marks\n",
    "        Student.count += 1\n",
    "            \n",
    "    # Getter Method\n",
    "    def get_marks(self):\n",
    "        return self.__marks\n",
    "\n",
    "    #Setter Method\n",
    "    def set_marks(self, marks):\n",
    "        if marks >= 0 and marks <= 100:\n",
    "            self.__marks = marks\n",
    "        else:\n",
    "            print(\"Invalid Marks\")\n",
    "\n",
    "s = Student(85)\n",
