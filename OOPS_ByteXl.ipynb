  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "b4f27db7",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "1\n",
      "2\n",
      "3\n",
      "4\n",
      "5\n"
     ]
    }
   ],
   "source": [
    "class Numbers:\n",
    "    def __init__(self, maxx):\n",
    "        self.maxx = maxx\n",
    "\n",
    "    def __iter__(self):\n",
    "        self.num = 1\n",
    "        return self\n",
    "\n",
    "    def __next__(self):\n",
    "        if self.num <= self.maxx:\n",
    "            x=self.num\n",
    "            self.num+=1\n",
    "            return x\n",
    "        else:\n",
    "            raise StopIteration\n",
    "        \n",
    "obj = Numbers(5)\n",
    "for i in obj:\n",
    "    print(i)"
   ]
