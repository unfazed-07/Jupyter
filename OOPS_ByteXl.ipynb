    "### Abstraction\n",
    "Hiding implementation details and showing essential features to the user\n",
    "\n",
    "Abstract classes\n",
    "\n",
    "Abstract Methods (using abc module)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "958b1291",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Car starts with self-start\n",
      "Bike starts with self-start\n"
     ]
    }
   ],
   "source": [
    "from abc import ABC, abstractmethod\n",
    "\n",
    "class Vehicle(ABC):\n",
    "\n",
    "    @abstractmethod\n",
    "    def start(self):\n",
    "        pass\n",
    "\n",
    "# Concrete class\n",
    "class Car(Vehicle):\n",
    "    def start(self):\n",
    "        print(\"Car starts with self-start\")\n",
    "\n",
    "class Bike(Vehicle):\n",
    "    def start(self):\n",
    "        print(\"Bike starts with self-start\")\n",
    "\n",
    "c = Car()\n",
    "b = Bike()\n",
    "c.start()\n",
    "b.start()"
   ]
