    "#Fibonacci Series\n",
    "def fibonacci(n):\n",
    "    if n<=1:\n",
    "        return n  \n",
    "    return fibonacci(n-1)+fibonacci(n-2)\n",
    "\n",
    "for i in range(6):\n",
    "    print(fibonacci(i))"
   ]
